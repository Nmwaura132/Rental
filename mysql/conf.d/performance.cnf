[mysqld]
# ── Character set ─────────────────────────────────────────────────────────────
character-set-server       = utf8mb4
collation-server           = utf8mb4_unicode_ci

# ── InnoDB performance ────────────────────────────────────────────────────────
innodb_buffer_pool_size    = 256M      # raise to 70% of RAM in production
innodb_log_file_size       = 64M
innodb_flush_method        = O_DIRECT
innodb_flush_log_at_trx_commit = 1    # 1 = full ACID (safest for payments)
innodb_file_per_table      = 1

# ── Query cache / temp tables ─────────────────────────────────────────────────
tmp_table_size             = 64M
max_heap_table_size        = 64M

# ── Connections ───────────────────────────────────────────────────────────────
max_connections            = 100
wait_timeout               = 600
interactive_timeout        = 600

# ── Slow query log (dev & staging) ───────────────────────────────────────────
slow_query_log             = 1
slow_query_log_file        = /var/lib/mysql/slow.log
long_query_time            = 1        # log queries taking > 1s

# ── Security ──────────────────────────────────────────────────────────────────
local_infile               = 0        # disable LOAD DATA LOCAL INFILE
symbolic-links             = 0

[client]
default-character-set      = utf8mb4
